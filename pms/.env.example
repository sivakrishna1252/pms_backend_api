# Jenkins / server — copy to pms/.env (secrets: use Jenkins credentials file or server path only)
#
# Database: without DATABASE_URL Django uses SQLite (fine for solo dev).
# Deployed stacks should set DATABASE_URL so users, projects, and media refs live on PostgreSQL.

# DATABASE_URL=postgresql://USER:PASSWORD@HOSTNAME:5432/DBNAME
# Managed providers often need TLS, e.g. add ?sslmode=require to the URL.

DJANGO_SECRET_KEY=__REPLACE_WITH_LONG_RANDOM_SECRET__
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,__YOUR_SERVER_IP__

# Used by Jenkins stage "Ensure superuser" (ensure_superuser command; Django /admin + DB user)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=__REPLACE_STRONG_PASSWORD__
DJANGO_SUPERUSER_PROMOTE_EXISTING=false

APP_PORT=6009
CORS_ALLOW_ALL_ORIGINS=True
ALLOWED_OFFICE_EMAIL_DOMAIN=@apparatus.solutions

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

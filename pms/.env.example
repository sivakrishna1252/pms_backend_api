DJANGO_SECRET_KEY=django-insecure-change-this-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,187.127.139.247
APP_PORT=6009

# Admin CSRF when opening Django over http://IP:PORT — exact scheme/host/port must match browser.
CSRF_TRUSTED_ORIGINS=http://187.127.139.247:6009

# Superuser is stored only on that server’s DB. Options:
# A) One-time on the server: python manage.py createsuperuser
# B) Auto-create on container start (Dockerfile.prod): set all three below — only runs if user does not exist.
# DJANGO_SUPERUSER_USERNAME=pms
# DJANGO_SUPERUSER_EMAIL=you@apparatus.solutions
# DJANGO_SUPERUSER_PASSWORD=your-strong-secret

CORS_ALLOW_ALL_ORIGINS=True
ALLOWED_OFFICE_EMAIL_DOMAIN=@apparatus.solutions

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

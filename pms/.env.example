# =============================================================================
# Jenkins / production — copy into Jenkins Secret file or server `pms/.env`
# =============================================================================

DJANGO_SECRET_KEY=__REPLACE_WITH_LONG_RANDOM_SECRET__
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,__YOUR_SERVER_IP__

DJANGO_SUPERUSER_USERNAME=__REPLACE__
DJANGO_SUPERUSER_EMAIL=youruser@apparatus.solutions
DJANGO_SUPERUSER_PASSWORD=__REPLACE_STRONG_PASSWORD__
DJANGO_SUPERUSER_PROMOTE_EXISTING=false

CORS_ALLOW_ALL_ORIGINS=True
ALLOWED_OFFICE_EMAIL_DOMAIN=@apparatus.solutions
APP_PORT=6009

# -----------------------------------------------------------------------------
# ONE database for laptop + server → PostgreSQL only (same POSTGRES_* everywhere)
# -----------------------------------------------------------------------------
DB_ENGINE=postgresql
POSTGRES_DB=pms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__REPLACE__
# Host where PostgreSQL listens (often your app server IP). Laptop + Jenkins .env use this SAME value.
POSTGRES_HOST=__YOUR_POSTGRES_HOST__
POSTGRES_PORT=5432
# From Docker on the same machine as Postgres: POSTGRES_HOST=host.docker.internal (Windows/Mac Desktop)
# or the host LAN IP. Open pg_hba.conf + listen_addresses on the Postgres server.

# Portal JWT admin (optional; used by bootstrap_dashboard_admin)
BOOTSTRAP_ADMIN_EMAIL=siva@apparatus.solutions
BOOTSTRAP_ADMIN_PASSWORD=siva

# -----------------------------------------------------------------------------
# SQLite instead (separate file per machine unless you copy db.sqlite3)
# -----------------------------------------------------------------------------
# DB_ENGINE=sqlite
# SQLITE_DB_PATH=/app/dbdata/db.sqlite3
# (Jenkins mounts sqlite-data only when DB_ENGINE is not postgresql.)

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# =============================================================================
# Jenkins / production — copy into Jenkins Secret file or server `pms/.env`
# =============================================================================

DJANGO_SECRET_KEY=__REPLACE_WITH_LONG_RANDOM_SECRET__
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,__YOUR_SERVER_IP__

# Optional Django /admin superuser (ensure_superuser)
DJANGO_SUPERUSER_USERNAME=__REPLACE__
DJANGO_SUPERUSER_EMAIL=youruser@apparatus.solutions
DJANGO_SUPERUSER_PASSWORD=__REPLACE_STRONG_PASSWORD__
DJANGO_SUPERUSER_PROMOTE_EXISTING=false

CORS_ALLOW_ALL_ORIGINS=True
ALLOWED_OFFICE_EMAIL_DOMAIN=@apparatus.solutions
APP_PORT=6009

# -----------------------------------------------------------------------------
# Database — SQLite (default) or PostgreSQL
# -----------------------------------------------------------------------------
# SQLite: omit DB_ENGINE or set DB_ENGINE=sqlite
DB_ENGINE=sqlite
# Default file: pms/db.sqlite3. For Jenkins/Docker prod (persistent volume /app/dbdata):
SQLITE_DB_PATH=/app/dbdata/db.sqlite3
# Dev docker-compose with bind mount .:/app can omit SQLITE_DB_PATH (uses project db.sqlite3).

# Optional: JWT dashboard admin defaults for `bootstrap_dashboard_admin` / Jenkins checkbox
# Login API body always uses "email" (not username): use full office email.
BOOTSTRAP_ADMIN_EMAIL=siva@apparatus.solutions
BOOTSTRAP_ADMIN_PASSWORD=siva

# PostgreSQL (only if DB_ENGINE=postgresql)
# POSTGRES_DB=pms
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=__REPLACE__
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# If FATAL "no pg_hba.conf entry", fix pg_hba.conf on the Postgres server or use 127.0.0.1 from same host.

# Copying one SQLite file between laptop and server (testing only): copy the whole `sqlite-data/`
# folder (or db.sqlite3) to the Jenkins SQLITE_HOST_DIR path on the server, then deploy.

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

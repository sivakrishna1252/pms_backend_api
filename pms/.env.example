# =============================================================================
# Jenkins / production — copy this whole file into your Jenkins credential
# (Secret file) or server `pms/.env`, then replace every placeholder.
# =============================================================================

# Required: long random string (do not use the example in production)
DJANGO_SECRET_KEY=__REPLACE_WITH_LONG_RANDOM_SECRET__

# Production: False | Local dev: True
DEBUG=False

# Comma-separated hosts (no spaces). Include your server IP and domains.
ALLOWED_HOSTS=127.0.0.1,localhost,__YOUR_SERVER_IP__

# Exact browser origin for admin POST (scheme + IP/domain + port — no path).
# Examples (use the URL you actually open in Chrome; port must match Jenkins map or reverse proxy):
CSRF_TRUSTED_ORIGINS=http://__YOUR_SERVER_IP__:6009
# If you access admin on another port, use that instead or add a second origin (comma-separated).

# SQLite persistence for Docker/Jenkins (named volume mounts /data). Matches docker-compose.prod + Jenkinsfile.
DATABASE_PATH=/data/db.sqlite3

# First deploy only: auto-create Django superuser if missing. Remove or leave blank after login works.
DJANGO_SUPERUSER_USERNAME=__REPLACE__
DJANGO_SUPERUSER_EMAIL=youruser@apparatus.solutions
DJANGO_SUPERUSER_PASSWORD=__REPLACE_STRONG_PASSWORD__

# If you created the user manually without is_staff=True, set this once then redeploy — user is promoted + password set from env.
DJANGO_SUPERUSER_PROMOTE_EXISTING=false

# API CORS (JWT / frontend)
CORS_ALLOW_ALL_ORIGINS=True

# Office email domain gate (login + invites)
ALLOWED_OFFICE_EMAIL_DOMAIN=@apparatus.solutions

# Optional: port label for docs / docker-compose.local only (Jenkins uses its own HOST_PORT in Jenkinsfile)
APP_PORT=6009

# -----------------------------------------------------------------------------
# Optional SMTP (deadline emails, etc.)
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

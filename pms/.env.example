# =============================================================================
# Jenkins / production — copy into Jenkins Secret file or server `pms/.env`
# =============================================================================

DJANGO_SECRET_KEY=__REPLACE_WITH_LONG_RANDOM_SECRET__
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,__YOUR_SERVER_IP__

# Optional bootstrap (run manually: docker exec … python manage.py ensure_superuser)
DJANGO_SUPERUSER_USERNAME=__REPLACE__
DJANGO_SUPERUSER_EMAIL=youruser@apparatus.solutions
DJANGO_SUPERUSER_PASSWORD=__REPLACE_STRONG_PASSWORD__
DJANGO_SUPERUSER_PROMOTE_EXISTING=false

CORS_ALLOW_ALL_ORIGINS=True
ALLOWED_OFFICE_EMAIL_DOMAIN=@apparatus.solutions
# Host port for docker run / docker-compose (container listens on 8000; map e.g. 6009:8000).
APP_PORT=6009

# Database: sqlite (default) or postgresql
# DB_ENGINE=postgresql
# POSTGRES_DB=pms
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=__REPLACE__
# POSTGRES_HOST: 127.0.0.1 only when Django runs ON the host (venv). When Django runs in Docker on
# Windows/Mac and Postgres is on the host, use POSTGRES_HOST=host.docker.internal
# POSTGRES_HOST=host.docker.internal
# POSTGRES_PORT=5432
# If Postgres requires TLS: POSTGRES_SSLMODE=require
# If FATAL "no pg_hba.conf entry for host …": on the Postgres SERVER edit pg_hba.conf to allow your
# client IP (or use 127.0.0.1 when Django and Postgres are on the same OS), then reload config.
# Example line (dev): host  pms  postgres  192.168.1.0/24  scram-sha-256
# Linux Docker (no host.docker.internal): use the host LAN IP or add extra_hosts in compose.
# Optional pool: DB_CONN_MAX_AGE=60

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

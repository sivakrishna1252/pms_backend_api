# Jenkins / server — copy to pms/.env (secrets: use Jenkins credentials file or server path only)
#
# Database: without DATABASE_URL Django uses SQLite (fine for solo dev).
# Deployed stacks should set DATABASE_URL so users, projects, and media refs live on PostgreSQL.

# DATABASE_URL=postgresql://USER:PASSWORD@HOSTNAME:5432/DBNAME
# Managed providers often need TLS, e.g. add ?sslmode=require to the URL.

DJANGO_SECRET_KEY=__REPLACE_WITH_LONG_RANDOM_SECRET__
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,187.127.139.247,nexus-pms.aspune.cloud

# Used by Jenkins stage "Ensure superuser" (ensure_superuser command; Django /admin + DB user)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=__REPLACE_STRONG_PASSWORD__
DJANGO_SUPERUSER_PROMOTE_EXISTING=false

APP_PORT=6009
CORS_ALLOW_ALL_ORIGINS=True
ALLOWED_OFFICE_EMAIL_DOMAIN=@apparatus.solutions
FRONTEND_LOGIN_URL=http://nexus.aspune.cloud/auth/login
FRONTEND_FIRST_LOGIN_URL=http://nexus.aspune.cloud/auth/activate-account

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Task timer auto-stop (Mon-Sat 8 PM local). Used by manage.py auto_stop_task_timers.
TIME_ZONE=Asia/Kolkata
AUTO_STOP_CUTOFF_HOUR=20
AUTO_STOP_CUTOFF_MINUTE=0

# Admin timer log history: hide sessions before this local date (set on deploy, e.g. 2026-07-02).
# Leave empty to show only the current local day onward.
TIMER_LOGS_VISIBLE_FROM=

# Same value as attendance_service PMS_SERVICE_TOKEN (internal notifications API).
PMS_SERVICE_TOKEN=__REPLACE_WITH_LONG_RANDOM_SECRET__

# Admin AI (read-only). Default provider: Sarvam cloud.
AI_PROVIDER=sarvam
SARVAM_API_KEY=__REPLACE_WITH_SARVAM_API_KEY__
SARVAM_MODEL=sarvam-30b
SARVAM_BASE_URL=https://api.sarvam.ai/v1
SARVAM_TIMEOUT=120

# Optional local fallback (set AI_PROVIDER=ollama). See pms/OLLAMA_SERVER.md
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT=180

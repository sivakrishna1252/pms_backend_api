# =============================================================================
# Jenkins / production — copy into Jenkins Secret file or server `pms/.env`
# =============================================================================

DJANGO_SECRET_KEY=__REPLACE_WITH_LONG_RANDOM_SECRET__
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,__YOUR_SERVER_IP__

# Optional bootstrap (run manually: docker exec … python manage.py ensure_superuser)
DJANGO_SUPERUSER_USERNAME=__REPLACE__
DJANGO_SUPERUSER_EMAIL=youruser@apparatus.solutions
DJANGO_SUPERUSER_PASSWORD=__REPLACE_STRONG_PASSWORD__
DJANGO_SUPERUSER_PROMOTE_EXISTING=false

CORS_ALLOW_ALL_ORIGINS=True
ALLOWED_OFFICE_EMAIL_DOMAIN=@apparatus.solutions
# Host port for docker run / docker-compose (container listens on 8000; map e.g. 6009:8000).
APP_PORT=6009

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

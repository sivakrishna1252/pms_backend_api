pipeline {
    agent any

    environment {
        APP_NAME = "pms-web-prod"
        IMAGE_NAME = "pms-backend"
        ENV_ID = "pms_backend_env"
        ENV_FILE = ".env"
        HOST_PORT = "6009"
        CONTAINER_PORT = "8000"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    test -f ${ENV_FILE} || (echo "${ENV_FILE} file missing in workspace"; exit 1)
                """
                sh """
                    docker build -f Dockerfile.prod -t ${IMAGE_NAME}:${BUILD_NUMBER} -t ${IMAGE_NAME}:latest .
                """
            }
        }

        stage('Validate App') {
            steps {
                sh """
                    docker run --rm --env-file ${ENV_FILE} ${IMAGE_NAME}:${BUILD_NUMBER} python manage.py check
                """
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    test -f ${ENV_FILE} || (echo "${ENV_FILE} file missing in workspace"; exit 1)
                    docker rm -f ${APP_NAME} || true
                    docker run -d \
                      --name ${APP_NAME} \
                      --restart unless-stopped \
                      --env-file ${ENV_FILE} \
                      -p ${HOST_PORT}:${CONTAINER_PORT} \
                      ${IMAGE_NAME}:${BUILD_NUMBER}
                """
            }
        }
    }

    post {
        success {
            echo "Deployment successful. App is available on port ${HOST_PORT}."
        }
        failure {
            echo "Pipeline failed. Check build logs."
        }
    }
}

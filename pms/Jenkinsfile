pipeline {
    agent any

    environment {
        PROJECT_DIR = "pms"
        APP_NAME = "pms-web-prod"
        IMAGE_NAME = "pms-backend"
        ENV_ID = "pms_backend_env"
        ENV_FILE = ".env"
        ALLOWED_HOSTS_VALUE = "127.0.0.1,localhost,187.127.139.247"
        APP_PORT_DEFAULT = "6009"
        CONTAINER_PORT = "8000"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    cd ${PROJECT_DIR}
                    if [ ! -f ${ENV_FILE} ]; then
                        if [ -f .env.example ]; then
                            cp .env.example ${ENV_FILE}
                            echo "${ENV_FILE} created from .env.example"
                        else
                            touch ${ENV_FILE}
                            echo "${ENV_FILE} created as empty fallback"
                        fi
                    fi
                    docker build -f Dockerfile.prod -t ${IMAGE_NAME}:${BUILD_NUMBER} -t ${IMAGE_NAME}:latest .
                """
            }
        }

        stage('Validate App') {
            steps {
                sh """
                    cd ${PROJECT_DIR}
                    docker run --rm --env-file ${ENV_FILE} -e ALLOWED_HOSTS="${ALLOWED_HOSTS_VALUE}" ${IMAGE_NAME}:${BUILD_NUMBER} python manage.py check
                """
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    cd ${PROJECT_DIR}
                    if [ ! -f ${ENV_FILE} ]; then
                        if [ -f .env.example ]; then
                            cp .env.example ${ENV_FILE}
                            echo "${ENV_FILE} created from .env.example"
                        else
                            touch ${ENV_FILE}
                            echo "${ENV_FILE} created as empty fallback"
                        fi
                    fi
                """
                script {
                    def envPath = "${env.WORKSPACE}/${env.PROJECT_DIR}/${env.ENV_FILE}"
                    def publishPort = "${env.APP_PORT_DEFAULT}"
                    if (fileExists(envPath)) {
                        def text = readFile(envPath)
                        def matcher = (text =~ /(?m)^\s*APP_PORT\s*=\s*(\S+)/)
                        if (matcher.find()) {
                            publishPort = matcher.group(1).trim()
                        }
                    }
                    env.PUBLISH_PORT = publishPort
                }
                sh """
                    cd ${PROJECT_DIR}
                    docker rm -f ${APP_NAME} || true
                    docker run -d \\
                      --name ${APP_NAME} \\
                      --restart unless-stopped \\
                      --env-file ${ENV_FILE} \\
                      -e ALLOWED_HOSTS="${ALLOWED_HOSTS_VALUE}" \\
                      -p ${env.PUBLISH_PORT}:${env.CONTAINER_PORT} \\
                      ${IMAGE_NAME}:${BUILD_NUMBER}
                """
            }
        }
    }

    post {
        success {
            echo "Deployment successful. App is available on host port ${env.PUBLISH_PORT} (container ${env.CONTAINER_PORT})."
        }
        failure {
            echo "Pipeline failed. Check build logs."
        }
    }
}

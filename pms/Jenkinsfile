pipeline {
    agent any

    environment {
        PROJECT_DIR = "pms"
        APP_NAME = "pms-web-prod"
        IMAGE_NAME = "pms-backend"
        ENV_FILE = ".env"
        ALLOWED_HOSTS_VALUE = "127.0.0.1,localhost,187.127.139.247"
        HOST_PORT = "6009"
        CONTAINER_PORT = "8000"
        // Host path for SQLite so redeploys keep the same DB on the *Jenkins agent* (not your laptop).
        SQLITE_ON_AGENT = "${WORKSPACE}/${PROJECT_DIR}/db.sqlite3"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    cd ${PROJECT_DIR}
                    if [ ! -f ${ENV_FILE} ]; then
                        if [ -f .env.example ]; then
                            cp .env.example ${ENV_FILE}
                        else
                            touch ${ENV_FILE}
                        fi
                    fi
                    docker build -f Dockerfile.prod -t ${IMAGE_NAME}:${BUILD_NUMBER} -t ${IMAGE_NAME}:latest .
                """
            }
        }

        stage('Validate App') {
            steps {
                sh """
                    cd ${PROJECT_DIR}
                    docker run --rm --env-file ${ENV_FILE} -e ALLOWED_HOSTS="${ALLOWED_HOSTS_VALUE}" ${IMAGE_NAME}:${BUILD_NUMBER} python manage.py check
                """
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    cd ${PROJECT_DIR}
                    if [ ! -f ${ENV_FILE} ]; then
                        if [ -f .env.example ]; then
                            cp .env.example ${ENV_FILE}
                        else
                            touch ${ENV_FILE}
                        fi
                    fi
                    # One SQLite file on the agent, reused by every new container → same server DB across deploys.
                    # Your local PC still uses its own pms/db.sqlite3 unless you copy this file or use shared Postgres.
                    touch "${SQLITE_ON_AGENT}" || true
                    chmod 666 "${SQLITE_ON_AGENT}" 2>/dev/null || true
                    docker rm -f ${APP_NAME} || true
                    docker run -d \\
                      --name ${APP_NAME} \\
                      --restart unless-stopped \\
                      --env-file ${ENV_FILE} \\
                      -e ALLOWED_HOSTS="${ALLOWED_HOSTS_VALUE}" \\
                      -v "${SQLITE_ON_AGENT}:/app/db.sqlite3" \\
                      -p ${HOST_PORT}:${CONTAINER_PORT} \\
                      ${IMAGE_NAME}:${BUILD_NUMBER}
                """
            }
        }

        // Apply Django migrations against the mounted SQLite DB (idempotent).
        stage('Migrate database') {
            steps {
                sh """
                    sleep 3
                    docker exec ${APP_NAME} python manage.py migrate --noinput
                """
            }
        }

        // Uses DJANGO_SUPERUSER_USERNAME / DJANGO_SUPERUSER_EMAIL / DJANGO_SUPERUSER_PASSWORD from ${ENV_FILE}.
        // Creates or promotes Django admin login for /admin/ — see pms_api.management.commands.ensure_superuser
        stage('Ensure superuser') {
            steps {
                sh """
                    docker exec ${APP_NAME} python manage.py ensure_superuser || true
                """
            }
        }
    }

    post {
        success {
            echo "Deployment successful. App is available on port ${HOST_PORT}."
        }
        failure {
            echo "Pipeline failed. Check build logs."
        }
    }
}
